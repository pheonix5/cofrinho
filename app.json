{
  "expo": {
    "name": "Cofrinho",
    "slug": "cofrinho",
    "scheme": "cofrinho",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0B0B0F",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.POST_NOTIFICATIONS"
      ],
      "package": "com.lucasfelix413.cofrinho"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-status-bar",
      "expo-sqlite",
      "expo-sharing",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "imageWidth": 220,
          "resizeMode": "contain",
          "backgroundColor": "#0B0B0F"
        }
      ],
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "Permitir que o Cofrinho acesse o microfone para lançamentos por voz.",
          "speechRecognitionPermission": "Permitir que o Cofrinho reconheça sua voz para criar lançamentos."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/android-icon-monochrome.png",
          "color": "#9AE66E",
          "defaultChannel": "quick-action"
        }
      ],
      "@react-native-community/datetimepicker"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "405e60b4-0f82-42bd-8e1b-5f3977787c48"
      }
    }
  }
}
